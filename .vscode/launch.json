{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Train Diffusion",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/src/pipelines/training/training_pipeline_ip.py",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Inference Diffusion",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/src/pipelines/inference/inference_pipeline_ip.py",
      "console": "integratedTerminal",
      "env": {
      "PYTHONPATH": "${workspaceFolder}"
      },
      "args": [

      "--checkpoint", "checkpoints/prog-disease-generation-ip-final/uqqx9kg9/checkpoints/ip-ddpm-epochepoch=0149.ckpt",
      "--config", "configs/train_ip.yaml",
      "--sampling-steps", "50",
      "--mes-steps", "13",
      "--output-dir", "paper_outputs/paper_outputs_steer_vs_noguidance/uqqx9kg9/UC_patient_415_9",
      "--structure-image", "data/limuc_cleaned/test/2/UC_patient_415_9.bmp",
      "--no-blur",
      "--image-scale", "1",
      "--source-label", "2",
      "--steer-scale", "2.5",
      "--seed", "1",
      ]

    },
     {
      "name": "Inference Diffusion Data Augment",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/src/pipelines/inference/inference_pipeline_ip_data_augment.py",
      "console": "integratedTerminal",
      "env": {
      "PYTHONPATH": "${workspaceFolder}"
      },
      "args": [
      "--checkpoint", "prog-disease-generation-ip/uqqx9kg9/checkpoints/ip-ddpm-epochepoch=0149.ckpt",
      "--config", "configs/train_ip.yaml",
      "--data-root", "data/limuc_cleaned",
      "--output-root", "data/limuc_cleaned_balanced_uqqx9kg9_steer_15",
      "--sampling-steps", "50",
      "--guidance-scale", "1",
      "--image-scale", "1",
      "--steer-scale", "1.5",
      "--no-blur",
      "--seed", "42",
      "--batch-images", "8",
      "--save-workers", "4"
      ]
    },
    {
      "name": "Inference Diffusion Inverted",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/src/pipelines/inference_pipeline.py",
      "console": "integratedTerminal",
      "env": {
      "PYTHONPATH": "${workspaceFolder}"
      },
      "args": [
      "--checkpoint", "/home/umut_dundar/repositories/progressive-stable-diffusion/prog-disease-generation/c8o3zs2i/checkpoints/ddpm-epochepoch=0099.ckpt",
      "--config", "configs/train.yaml",
      "--sampling-steps", "50",
      "--mes-steps", "20",
      "--output-dir", "outputs_inverted/c8o3zs2i_test_3_UC_patient_199_47",
      //"--structure-image", "/home/umut_dundar/repositories/progressive-stable-diffusion/data/limuc/processed_data/test/3/UC_patient_239_112.bmp",
      "--structure-image", "/home/umut_dundar/repositories/progressive-stable-diffusion/data/limuc/processed_data/test/3/UC_patient_199_47.bmp",
      "--guidance-scale", "1.0",
      "--use-ddim-invert"
      ]
    },
    {
      "name": "Classifier Training",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/src/classification/train.py",
      "console": "integratedTerminal",
      "env": {
      "PYTHONPATH": "${workspaceFolder}"
      },
      "args": [
      "--config", "configs/train_classifier.yaml",

      ]
    },

  ]
